# 复制本文件为 .env 并按需填写

# 站点正式域名（不填默认 https://wuxing-beasts.com）
SITE_URL=https://wuxing-beasts.com

# Plausible 自托管或 plausible.io 的 domain
# PUBLIC_PLAUSIBLE_DOMAIN=wuxing-beasts.com

# Google Analytics 4 measurement id
# PUBLIC_GA_ID=G-XXXXXXXXXX

# 实体盲盒外链（默认 lulumart.app）
PUBLIC_LULUMART_URL=https://lulumart.app
