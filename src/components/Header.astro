---
import type { Locale } from "@/i18n/types";
import { LOCALES, LOCALE_LABELS } from "@/i18n/types";
import { getDict, localizedPath, switchLocaleHref } from "@/i18n";

interface Props {
  lang: Locale;
  current?: string;
}
const { lang, current = "" } = Astro.props;
const t = getDict(lang);

const links = [
  { id: "home",     href: localizedPath("/",          lang), label: t.nav.home },
  { id: "origin",   href: localizedPath("/origin",    lang), label: t.nav.origin },
  { id: "beasts",   href: localizedPath("/beasts",    lang), label: t.nav.beasts },
  { id: "series",   href: localizedPath("/series",    lang), label: t.nav.series },
];

const resonanceHref = localizedPath("/resonance", lang);
const homeHref = localizedPath("/", lang);

// 当前 path（用于切换语言时保持页面）
const currentPath = Astro.url.pathname;
const switchTargets = LOCALES.map((l) => ({
  locale: l,
  href: switchLocaleHref(currentPath, l),
  short: LOCALE_LABELS[l].short,
  long: LOCALE_LABELS[l].long,
}));
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href={homeHref} class="brand" aria-label={t.nav.homeAria}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 40 40" width="28" height="28" fill="none">
          <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-opacity="0.35"/>
          <circle cx="20" cy="6"  r="1.6" fill="#F1D687"/>
          <circle cx="33" cy="15" r="1.6" fill="#A8D6A8"/>
          <circle cx="28" cy="32" r="1.6" fill="#9CCDE8"/>
          <circle cx="12" cy="32" r="1.6" fill="#F5A6B8"/>
          <circle cx="7"  cy="15" r="1.6" fill="#D8B795"/>
          <text x="20" y="24" text-anchor="middle" font-family="Noto Serif SC, serif" font-size="13" fill="currentColor">五</text>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-zh">{t.brand.name}</span>
        <span class="brand-latin">{t.brand.nameLatin}</span>
      </span>
    </a>

    <nav class="primary" aria-label={t.nav.primaryAria}>
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href} class:list={["nav-link", { 'is-current': current === l.id }]}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="end">
      <div class="lang-switch" role="group" aria-label={t.nav.switcherAria}>
        {switchTargets.map((s) => (
          <a
            href={s.href}
            class:list={["lang-chip", { 'is-active': s.locale === lang }]}
            hreflang={LOCALE_LABELS[s.locale].html}
            aria-current={s.locale === lang ? "true" : undefined}
            title={s.long}
          >
            {s.short}
          </a>
        ))}
      </div>

      <a href={resonanceHref} class="btn btn-primary header-cta" data-event="header_resonance">
        <span>{t.nav.headerCta}</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <button class="menu-toggle" type="button" aria-label={t.nav.mobileToggleOpen} aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="mobile-nav" class="mobile-nav" hidden>
    <ul>
      {links.map((l) => (
        <li><a href={l.href} class:list={["nav-link", { 'is-current': current === l.id }]}>{l.label}</a></li>
      ))}
      <li><a href={resonanceHref} class="nav-link nav-cta">{t.nav.headerCta}</a></li>
      <li class="mobile-lang">
        {switchTargets.map((s) => (
          <a
            href={s.href}
            class:list={["lang-chip", { 'is-active': s.locale === lang }]}
            hreflang={LOCALE_LABELS[s.locale].html}
          >
            {s.long}
          </a>
        ))}
      </li>
    </ul>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    background: linear-gradient(180deg, rgba(12,10,20,0.78), rgba(12,10,20,0.45) 80%, transparent);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    height: 4.4rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-cloud);
  }

  .brand-mark {
    color: var(--color-cloud);
    display: inline-flex;
    transition: transform 0.6s var(--ease-silk);
  }
  .brand:hover .brand-mark { transform: rotate(45deg); }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand-zh {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    letter-spacing: 0.18em;
  }
  :global(html[data-locale="en"]) .brand-zh {
    font-family: var(--font-display);
    font-style: italic;
    letter-spacing: 0.06em;
  }
  .brand-latin {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    color: var(--color-cloud-dim);
    opacity: 0.7;
    text-transform: uppercase;
  }
  :global(html[data-locale="en"]) .brand-latin {
    text-transform: none;
    letter-spacing: 0.18em;
    font-style: normal;
  }

  .primary {
    display: none;
  }
  .primary ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    letter-spacing: 0.22em;
    color: var(--color-cloud-dim);
    transition: color 0.3s var(--ease-silk);
  }
  :global(html[data-locale="en"]) .nav-link {
    font-family: var(--font-display);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -8px;
    height: 1px;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    transform: scaleX(0);
    transition: transform 0.4s var(--ease-silk);
  }
  .nav-link:hover { color: var(--color-cloud); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-current { color: var(--color-cloud); }
  .nav-link.is-current::after { transform: scaleX(1); }

  .end {
    display: none;
    align-items: center;
    gap: 0.85rem;
  }

  .header-cta {
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    letter-spacing: 0.22em;
  }
  .cta-arrow { transition: transform 0.4s var(--ease-silk); }
  .header-cta:hover .cta-arrow { transform: translateX(4px); }

  .lang-switch {
    display: inline-flex;
    padding: 0.25rem;
    gap: 0.15rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .lang-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 1.85rem;
    padding: 0 0.7rem;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    color: var(--color-cloud-dim);
    transition: background 0.3s var(--ease-silk), color 0.3s var(--ease-silk);
  }
  .lang-chip:hover { color: var(--color-cloud); }
  .lang-chip.is-active {
    background: rgba(255,255,255,0.12);
    color: var(--color-cloud);
  }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.03);
  }
  .menu-toggle span {
    display: block;
    width: 16px;
    height: 1px;
    margin: 0 auto;
    background: currentColor;
    transition: transform 0.3s var(--ease-silk), opacity 0.3s var(--ease-silk);
  }

  .mobile-nav {
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(12,10,20,0.92);
    backdrop-filter: blur(18px);
  }
  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .mobile-nav .nav-cta {
    color: var(--color-jin);
  }
  .mobile-lang {
    margin-top: 0.6rem;
    display: flex;
    gap: 0.4rem;
  }

  @media (min-width: 880px) {
    .primary, .end { display: inline-flex; }
    .menu-toggle { display: none; }
    .mobile-nav { display: none !important; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const nav = document.querySelector<HTMLElement>("#mobile-nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const open = !nav.hasAttribute("hidden");
      if (open) nav.setAttribute("hidden", "");
      else nav.removeAttribute("hidden");
      toggle.setAttribute("aria-expanded", String(!open));
    });
  }
</script>
