---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getShichen, styleFromShichen } from "@/lib/time";
import { DEFAULT_LOCALE, LOCALE_LABELS, LOCALES, type Locale } from "@/i18n/types";
import { getDict, localizedPath } from "@/i18n";

interface Props {
  lang: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  pageId?: string;
  noFooter?: boolean;
  noHeader?: boolean;
  noAura?: boolean;
  bodyClass?: string;
  /** 当前页面的"逻辑路径"（不带 locale 前缀），用于生成 hreflang alternates */
  logicalPath?: string;
}

const {
  lang,
  title,
  description,
  ogImage = "/share/og-default.png",
  pageId = "page",
  noFooter = false,
  noHeader = false,
  noAura = false,
  bodyClass = "",
  logicalPath,
} = Astro.props;

const dict = getDict(lang);
const fallbackTitle = dict.meta.homeTitle;
const fullTitle = title ?? fallbackTitle;
const desc = description ?? dict.meta.homeDesc;

const shichen = getShichen();
const auraStyle = styleFromShichen(shichen);

const siteOrigin = Astro.site ?? new URL("https://wuxing-beasts.com");
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();

const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const gaId = import.meta.env.PUBLIC_GA_ID;

const htmlLang = LOCALE_LABELS[lang].html;

// hreflang alternates：传入 logicalPath（如 "/origin"），自动生成各 locale URL
const alternates = logicalPath
  ? LOCALES.map((l) => ({
      hreflang: LOCALE_LABELS[l].html,
      href: new URL(localizedPath(logicalPath, l), siteOrigin).toString(),
    }))
  : [];
const xDefault = logicalPath
  ? new URL(localizedPath(logicalPath, DEFAULT_LOCALE), siteOrigin).toString()
  : null;

const ogLocale = lang === "zh" ? "zh_CN" : "en_US";
const ogLocaleAlternate = lang === "zh" ? "en_US" : "zh_CN";
---

<!doctype html>
<html lang={htmlLang} data-page={pageId} data-shichen={shichen.name[lang]} data-locale={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta name="theme-color" content="#0c0a14" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={canonical} />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;500;600;700&display=swap"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, siteOrigin).toString()} />
    <meta property="og:site_name" content="Wǔ Xíng Beasts" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={new URL(ogImage, siteOrigin).toString()} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Brand",
        name: dict.brand.name,
        alternateName: lang === "zh" ? "Wǔ Xíng Beasts" : "五行小兽",
        url: canonical,
        logo: new URL("/icons/icon-512.png", siteOrigin).toString(),
        description: dict.brand.tagline,
        slogan: dict.brand.slogan,
        inLanguage: htmlLang,
      })}
    ></script>

    {plausibleDomain && (
      <script defer is:inline data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
    {gaId && (
      <>
        <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag("js", new Date());
          gtag("config", gaId, { anonymize_ip: true });
        </script>
      </>
    )}
  </head>

  <body class={bodyClass} style={auraStyle} data-locale={lang}>
    {!noAura && (
      <>
        <div class="shichen-aura" aria-hidden="true"></div>
        <div class="scrim-vignette" aria-hidden="true"></div>
      </>
    )}

    {!noHeader && <Header lang={lang} current={pageId} />}

    <main id="main">
      <slot />
    </main>

    {!noFooter && <Footer lang={lang} />}

    <script>
      import { getShichen, styleFromShichen, localizeShichen } from "@/lib/time";
      import { isLocale, DEFAULT_LOCALE } from "@/i18n/types";

      const localeAttr = document.documentElement.dataset.locale;
      const lang = isLocale(localeAttr ?? "") ? (localeAttr as "zh" | "en") : DEFAULT_LOCALE;

      function paint() {
        const s = getShichen();
        const style = styleFromShichen(s);
        const localized = localizeShichen(s, lang);
        document.body.setAttribute("style", style);
        document.documentElement.dataset.shichen = localized.name;
      }
      paint();
      setInterval(paint, 5 * 60 * 1000);
    </script>

    <script>
      const els = document.querySelectorAll(".fade-up");
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.18, rootMargin: "0px 0px -10% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
