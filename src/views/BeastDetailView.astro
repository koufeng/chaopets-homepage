---
import Base from "@/layouts/Base.astro";
import BeastStage from "@/components/BeastStage.astro";
import { beasts, beastsById, localizeBeast, type BeastId } from "@/data/beasts";
import { getDict, localizedPath } from "@/i18n";
import type { Locale } from "@/i18n/types";

interface Props {
  lang: Locale;
  beastId: BeastId;
}
const { lang, beastId } = Astro.props;
const t = getDict(lang);

const raw = beastsById[beastId];
const beast = localizeBeast(raw, lang);

const idx = beasts.findIndex((b) => b.id === beast.id);
const prev = localizeBeast(beasts[(idx - 1 + beasts.length) % beasts.length], lang);
const next = localizeBeast(beasts[(idx + 1) % beasts.length], lang);

const lulumartUrl = import.meta.env.PUBLIC_LULUMART_URL || "https://lulumart.app";
---

<Base
  lang={lang}
  title={`${beast.displayName} · ${t.beast.archive}`}
  description={`${beast.displayName} · ${beast.element} · ${beast.emotion} · ${beast.signature}`}
  pageId={`beast-${beast.id}`}
  logicalPath={`/beasts/${beast.id}`}
>
  <article
    class:list={["beast-page", `lang-${lang}`]}
    style={`--c-aura:${beast.palette.aura};--c-deep:${beast.palette.deep};--c-glow:${beast.palette.glow};--c-ink:${beast.palette.ink};--c-surface:${beast.palette.surface};--g1:${beast.palette.gradient[0]};--g2:${beast.palette.gradient[1]};--g3:${beast.palette.gradient[2]};`}
  >
    <header class="beast-hero">
      <div class="wrap beast-hero-grid">
        <aside class="stage-wrap fade-up">
          <BeastStage beast={beast} expanded particleCount={48} />
          <p class="hint" aria-hidden="true">{t.beast.rotateHint}</p>
        </aside>

        <div class="meta fade-up">
          <p class="eyebrow">{t.beast.archive} · {beast.element}</p>
          <h1 class="name">
            {lang === "zh" ? (
              <>
                <span class="primary">{beast.nameZh}</span>
                <span class="secondary">{beast.nameLatin}</span>
              </>
            ) : (
              <>
                <span class="primary">{beast.nameLatin}</span>
                <span class="secondary">{beast.nameZh}</span>
              </>
            )}
          </h1>
          <p class="tag">{beast.emotionTagline}</p>

          <p class="signature">{t.beast.sigPrefix}{beast.signature}{t.beast.sigSuffix}</p>

          <dl class="stats">
            <div>
              <dt>{t.beast.element}</dt>
              <dd>{beast.element}</dd>
            </div>
            <div>
              <dt>{t.beast.emotion}</dt>
              <dd>{beast.emotion}</dd>
            </div>
            <div>
              <dt>{t.beast.hour}</dt>
              <dd>{beast.hour.label}</dd>
            </div>
          </dl>

          <div class="beast-actions">
            <a href={localizedPath("/resonance", lang)} class="btn btn-primary" data-event="beast_to_resonance">
              {t.beast.ctaResonance}
            </a>
            <a href={lulumartUrl} rel="noopener" target="_blank" class="btn btn-ghost" data-event="beast_to_lulumart">
              {t.beast.ctaPurchase}
            </a>
          </div>
        </div>
      </div>
    </header>

    <section class="story">
      <div class="wrap story-grid">
        <div class="story-copy fade-up">
          <p class="eyebrow">{t.beast.storyPrologue}</p>
          <p class="opening text-balance">{beast.storyOpening}</p>
        </div>
        <ul class="fragments">
          {beast.storyFragments.map((f, i) => (
            <li class="fragment fade-up" style={`--delay:${i * 0.12}s`}>
              <span class="num">0{i + 1}</span>
              <p>{f}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <nav class="beast-nav">
      <div class="wrap nav-inner">
        <a href={localizedPath(`/beasts/${prev.id}`, lang)} class="nav-link" rel="prev">
          <span class="arrow">←</span>
          <span class="meta">
            <span class="meta-label">{t.beast.navPrev}</span>
            <span class="meta-name">{prev.displayName} · {prev.element}</span>
          </span>
        </a>
        <a href={localizedPath("/beasts", lang)} class="nav-back">{t.beast.navBack}</a>
        <a href={localizedPath(`/beasts/${next.id}`, lang)} class="nav-link nav-next" rel="next">
          <span class="meta">
            <span class="meta-label">{t.beast.navNext}</span>
            <span class="meta-name">{next.displayName} · {next.element}</span>
          </span>
          <span class="arrow">→</span>
        </a>
      </div>
    </nav>
  </article>
</Base>

<style>
  .beast-page {
    --beast-bg: linear-gradient(180deg, color-mix(in oklab, var(--c-deep) 35%, transparent) 0%, transparent 70%);
    background: var(--beast-bg);
    isolation: isolate;
  }

  .beast-hero { padding-block: 5rem 4rem; }

  .beast-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 880px) {
    .beast-hero-grid { grid-template-columns: 1.05fr 1fr; gap: 5rem; }
  }

  .stage-wrap { position: relative; }
  .stage-wrap .hint {
    text-align: center;
    margin-top: 0.8rem;
    color: var(--color-cloud-dim);
    font-family: var(--font-display);
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    opacity: 0.7;
  }

  .meta { display: flex; flex-direction: column; gap: 1.4rem; }

  .name {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 0;
  }
  .name .primary {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: 0.3em;
  }
  .lang-en .name .primary {
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-style: italic;
  }
  .name .secondary {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    letter-spacing: 0.32em;
    color: var(--color-cloud-dim);
    text-transform: uppercase;
    opacity: 0.8;
  }
  .lang-en .name .secondary {
    font-family: var(--font-serif);
    font-style: normal;
    text-transform: none;
    letter-spacing: 0.4em;
  }

  .tag {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--c-aura);
    letter-spacing: 0.04em;
  }

  .signature {
    margin: 0.5rem 0 0;
    padding: 1rem 1.25rem;
    border-left: 2px solid var(--c-aura);
    background: rgba(255, 255, 255, 0.03);
    font-family: var(--font-serif);
    color: var(--color-cloud);
    line-height: 1.85;
    border-radius: 0.4rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin: 0.5rem 0 0;
    padding: 1.2rem 1.4rem;
    background: rgba(255,255,255,0.04);
    border-radius: var(--radius-soft);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .stats > div { display: flex; flex-direction: column; gap: 0.3rem; }
  .stats dt {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.7rem;
    color: var(--color-cloud-dim);
    opacity: 0.7;
  }
  .stats dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    color: var(--color-cloud);
  }

  .beast-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .story { padding-block: 6rem; }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 880px) {
    .story-grid { grid-template-columns: 1fr 1.4fr; gap: 5rem; }
  }
  .opening {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    color: var(--c-aura);
    line-height: 1.85;
    margin: 0.5rem 0 0;
    letter-spacing: 0.04em;
  }
  .fragments {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .fragment {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
    padding: 1.4rem 1.6rem;
    border-left: 1px solid color-mix(in oklab, var(--c-aura) 40%, transparent);
    background: linear-gradient(120deg, color-mix(in oklab, var(--c-deep) 12%, transparent), transparent 70%);
    border-radius: 0.6rem;
    transition-delay: var(--delay);
  }
  .num {
    font-family: var(--font-display);
    color: var(--c-aura);
    letter-spacing: 0.32em;
    font-size: 0.9rem;
  }
  .fragment p {
    margin: 0;
    color: var(--color-cloud);
    line-height: 1.95;
  }

  .beast-nav {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 0;
  }
  .nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--color-cloud-dim);
    transition: color 0.4s var(--ease-silk);
  }
  .nav-link:hover { color: var(--color-cloud); }
  .nav-link .arrow {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.16);
    display: grid;
    place-items: center;
    transition: transform 0.4s var(--ease-silk), border-color 0.4s var(--ease-silk);
  }
  .nav-link:hover .arrow {
    border-color: var(--c-aura);
    transform: translateX(0);
  }
  .nav-link[rel="prev"]:hover .arrow { transform: translateX(-3px); }
  .nav-link.nav-next:hover .arrow { transform: translateX(3px); }
  .nav-link.nav-next { justify-content: flex-end; text-align: right; }

  .nav-link .meta-label {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.7rem;
    opacity: 0.6;
  }
  .nav-link .meta-name {
    display: block;
    font-family: var(--font-serif);
    letter-spacing: 0.18em;
    margin-top: 0.2rem;
    color: var(--color-cloud);
  }

  .nav-back {
    font-family: var(--font-serif);
    letter-spacing: 0.18em;
    color: var(--color-cloud-dim);
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    transition: background 0.4s var(--ease-silk);
  }
  .nav-back:hover {
    background: rgba(255,255,255,0.06);
    color: var(--color-cloud);
  }

  @media (max-width: 720px) {
    .nav-inner { grid-template-columns: 1fr; gap: 1rem; }
    .nav-link.nav-next { justify-content: flex-start; text-align: left; }
  }
</style>

<script>
  import { track, Events } from "@/lib/analytics";
  const beastId = document.documentElement.dataset.page?.replace("beast-", "") ?? "";
  track(Events.BEAST_VIEWED, { beast: beastId });
</script>
